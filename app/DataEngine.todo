## 10. Consuming the Engine

### In Client Components:
```typescript
"use client";

import { useDataEngine } from "@/context/DataEngineContext";

export function DashboardPage() {
  const engine = useDataEngine();
  const [data, setData] = useState<DashboardData | null>(null);
  
  useEffect(() => {
    engine.getDashboardData().then(setData);
  }, [engine]);
  
  if (!data) return <Skeleton />;
  // render with data
}
```

### In Server Components:
```typescript
// Direct import (when using API engine)
import { getDashboardData } from "@/lib/engine/server";

export default async function DashboardPage() {
  const data = await getDashboardData();
  // render with data
}
```
